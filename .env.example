# Optional server-wide model selection. Users supply their own xAI API key in the UI.
XAI_MODEL=grok-4.5

# Responses, TTS, voice discovery, and Imagine use the browser-supplied key.
# Voice selection, image model, aspect ratio, resolution, and playback
# preferences are also set in the UI.

# Optional remote MCP workspace for Code mode. xAI connects to this HTTPS
# Streaming HTTP/SSE server. Keep authorization and tool policy server-side.
BRAINWORM_MCP_URL=https://your-mcp.example.com/mcp
BRAINWORM_MCP_LABEL=workspace
BRAINWORM_MCP_DESCRIPTION=Repository files, git, and sandboxed build tools
BRAINWORM_MCP_AUTHORIZATION=Bearer your-scoped-token
# Comma-separated exact tool names. Build mode exposes only this list.
BRAINWORM_MCP_ALLOWED_TOOLS=read_file,list_files,search_files,apply_patch,run_tests
# Plan and Verify expose only this read-only subset. Empty disables MCP there.
BRAINWORM_MCP_READONLY_TOOLS=read_file,list_files,search_files,git_diff
# Deliberately unsafe escape hatch; omit when using an allowlist.
# BRAINWORM_MCP_ALLOW_ALL=true
